# URL endpoint ngrok untuk terjemahan Minang -> Indonesia
TRANSLATE_URL=https://<your-ngrok-subdomain>.ngrok-free.dev/terjemahkan

# Ngrok Auth Token (isi jika endpoint memerlukan autentikasi)
NGROK_AUTH_TOKEN=
